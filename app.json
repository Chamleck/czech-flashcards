{
  "expo": {
    "name": "Чеські картки",
    "slug": "czech-flashcards",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "assetBundlePatterns": [
      "**/*"
    ],
    "plugins": [
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#211527"
        }
      ]
    ],
    "android": {
      "package": "com.nick.czechflashcards",
      "backgroundColor": "#211527",
      "adaptiveIcon": {
        "backgroundColor": "#1e293b"
      }
    },
    "extra": {
      "eas": {
        "projectId": "d3627930-9fa8-45d8-9bb2-82f745df51b3"
      }
    },
    "owner": "chamleck"
  }
}
